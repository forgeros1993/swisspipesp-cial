# SwissPipe — exemple de configuration. Copier vers .env et renseigner.
# AUCUNE valeur réelle ici. .env est git-ignoré.

# --- Base de données (PostgreSQL via psycopg 3) ---
# Format SQLAlchemy 2.0 + psycopg 3 : postgresql+psycopg://user:pass@host:port/db
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@localhost:5432/swisspipe

# --- Application ---
APP_ENV=development          # development | staging | production
APP_DEBUG=false
LOG_LEVEL=INFO

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
